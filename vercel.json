{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(static/.*)",
      "dest": "/frontend/build/$1"
    },
    {
      "src": "/(.*\\.[a-zA-Z0-9]+)$",
      "dest": "/frontend/build/$1"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/frontend/build/index.html"
    }
  ]
}
